# ============================================
# WHATSAPP BUSINESS BOT CONFIGURATION
# ============================================

# Business Owner's WhatsApp Number (with country code, no + or spaces)
# Example: 1234567890 for USA, 919876543210 for India
OWNER_NUMBER=1234567890

# Bot Mode: 'development' or 'production'
# Development: Shows detailed logs
# Production: Minimal logs, optimized performance
NODE_ENV=development

# Session Name (keep unique per business)
SESSION_NAME=business_bot_session

# Auto-reply delay (in milliseconds) - simulates typing
TYPING_DELAY=1000